# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/healthcare_appointments

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Groq (LLM) — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# Brevo (Email) — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@yourclinic.com
BREVO_SENDER_NAME=City Health Clinic

# Google Calendar OAuth 2.0 — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/oauth/callback

# Slot hold TTL (minutes) — how long a slot is reserved while patient fills the symptom form
SLOT_HOLD_MINUTES=5

# Reminder job cron (default: every 15 minutes)
REMINDER_CRON=*/15 * * * *
